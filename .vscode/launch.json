{
    "configurations": [
        {
            "name": "Editor (Debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/build/apps/editor/Debug/TooDeeEditor.exe",
            "args": [
                "./editor/config.ini"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/runtime",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${workspaceFolder}/build/apps/editor/Debug;${env:PATH}"
                }
            ],
            "console": "integratedTerminal"
        }
    ]
}