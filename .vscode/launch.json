{
    "configurations": [
        {
            "name": "Editor (Debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "build all",
            "program": "${workspaceFolder}/build/apps/editor/Debug/TooDeeEditor.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/apps/editor",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${workspaceFolder}/build/apps/editor/Debug;${env:PATH}"
                },
                {
                    "name": "TOO_DEE_ENGINE_BUILD_EDITOR",
                    "value": "true"
                }
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Moving Shapes (Debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/build/examples/moving_shapes/Debug/MovingShapesApp.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/examples/moving_shapes",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${workspaceFolder}/build/examples/moving_shapes/Debug;${env:PATH}"
                }
            ],
            "console": "integratedTerminal"
        }
    ]
}